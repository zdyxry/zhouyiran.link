---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

interface LinkCard {
  title: string;
  description: string;
  url: string;
  icon: string;
  span?: 'col2';
  accent: string;
}

const links: LinkCard[] = [
  {
    title: 'Blog',
    description: 'Thoughts on software, infrastructure, and life',
    url: 'https://zdyxry.github.io',
    icon: 'blog',
    span: 'col2',
    accent: 'from-blue-50 to-indigo-50',
  },
  {
    title: 'GitHub',
    description: '@zdyxry',
    url: 'https://github.com/zdyxry',
    icon: 'github',
    accent: 'from-zinc-100 to-zinc-50',
  },
  {
    title: 'X / Twitter',
    description: '@zdyxry',
    url: 'https://x.com/zdyxry',
    icon: 'twitter',
    accent: 'from-sky-50 to-blue-50',
  },
  {
    title: 'NeoDB',
    description: 'Books, movies & more',
    url: 'https://neodb.social/users/zdyxry/',
    icon: 'neodb',
    span: 'col2',
    accent: 'from-emerald-50 to-teal-50',
  },
  {
    title: 'Strava',
    description: 'Running & cycling',
    url: 'https://www.strava.com/athletes/160667061',
    icon: 'strava',
    accent: 'from-orange-50 to-red-50',
  },
  {
    title: 'Instagram',
    description: '@zdyxry',
    url: 'https://www.instagram.com/zdyxry/',
    icon: 'instagram',
    accent: 'from-pink-50 to-purple-50',
  },
  {
    title: '豆瓣',
    description: '书影音记录',
    url: 'https://www.douban.com/people/62229099/',
    icon: 'douban',
    accent: 'from-green-50 to-emerald-50',
  },

];
---

<Layout title="Yiran Zhou">
  <main class="min-h-screen flex flex-col items-center justify-center px-4 py-16 sm:py-24">
    <!-- Profile Header -->
    <div class="text-center mb-12 sm:mb-16 animate-fade-in">
      <div class="relative inline-block mb-6">
        <img
          src="https://avatars.githubusercontent.com/u/12016373?v=4"
          alt="Yiran Zhou's avatar"
          width="96"
          height="96"
          class="w-24 h-24 rounded-full ring-2 ring-zinc-200 shadow-lg"
          loading="eager"
        />
      </div>
      <h1 class="text-3xl sm:text-4xl font-heading font-bold tracking-tight text-zinc-900">
        Yiran Zhou
      </h1>
    </div>

    <!-- Bento Grid -->
    <div class="w-full max-w-2xl grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 animate-fade-in-up">
      <!-- Location Card -->
      <div class="col-span-2 relative rounded-2xl border border-zinc-200 overflow-hidden group transition-all duration-300 hover:border-zinc-300 hover:shadow-lg hover:shadow-zinc-200/50">
        <img
          src="https://basemaps.cartocdn.com/light_nolabels/10/857/418.png"
          alt="Map showing location in Shanghai"
          class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 transition-opacity duration-300 scale-[1.8] origin-center"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-white/80 to-transparent" aria-hidden="true"></div>
        <div class="relative z-10 min-h-[120px]"></div>
        <div class="absolute z-10 bottom-3 right-3 sm:bottom-4 sm:right-4 flex items-center gap-1.5 text-zinc-600 bg-white/70 backdrop-blur-sm rounded-full px-3 py-1">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-500" aria-hidden="true">
            <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span class="font-heading font-semibold text-sm">Shanghai, China</span>
        </div>
      </div>

      {links.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            'bento-card group relative flex flex-col justify-between rounded-2xl border border-zinc-200 bg-white p-5 sm:p-6',
            'transition-all duration-300 ease-out cursor-pointer overflow-hidden',
            'hover:border-zinc-300 hover:shadow-lg hover:shadow-zinc-200/50 hover:-translate-y-0.5',
            'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50',
            link.span === 'col2' && 'col-span-2',
          ]}
        >
          <div class:list={[
            'absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl',
            link.accent,
          ]} aria-hidden="true" />

          <div class="relative z-10">
            <div class="mb-3 sm:mb-4 text-zinc-500 group-hover:text-zinc-700 transition-colors duration-200">
              <Icon name={link.icon} />
            </div>
            <h2 class="text-base sm:text-lg font-heading font-semibold text-zinc-800 group-hover:text-zinc-900 transition-colors duration-200">
              {link.title}
            </h2>
            <p class="mt-1 text-sm text-zinc-400 group-hover:text-zinc-500 transition-colors duration-200">
              {link.description}
            </p>
          </div>

          <div class="relative z-10 mt-4 self-end text-zinc-300 group-hover:text-zinc-500 transition-all duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3.333 12.667L12.667 3.333M12.667 3.333H5.333M12.667 3.333V10.667" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <footer class="mt-16 text-center text-sm text-zinc-400 animate-fade-in-delay">
      <p>© {new Date().getFullYear()} Yiran Zhou</p>
    </footer>
  </main>
</Layout>

<style>
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.6s ease-out both;
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out 0.15s both;
  }

  .animate-fade-in-delay {
    animation: fade-in 0.6s ease-out 0.3s both;
  }
</style>
